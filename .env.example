# Agent HQ — Environment Configuration
# Copy this file to .env and fill in your values
# All variables are optional — features gracefully disable when not set

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the HQ server listens on (default: 3100)
SERVER_PORT=3100

# Timezone for date/time display in the dashboard (default: UTC)
# Use IANA timezone names, e.g. America/New_York, Europe/London, Australia/Sydney
TIMEZONE=UTC

# ─── Dashboard Auth ───────────────────────────────────────────────────────────

# Path to the JSON file that stores the hashed dashboard password
# The file is created automatically on first password set via the dashboard UI
# Default: ./data/hq-auth.json
HQ_AUTH_FILE=./data/hq-auth.json

# ─── Tasks / Kanban Board ─────────────────────────────────────────────────────

# Absolute path to your TASKS.md file (Markdown Kanban board)
# The dashboard parses this into a Kanban view with Backlog / In Progress / Done columns
# Markers: - [ ] backlog  |  - [~] in-progress  |  - [x] done
# Leave blank to disable the Kanban view
TASKS_FILE=/path/to/your/TASKS.md

# ─── Claude Code Token Stats ──────────────────────────────────────────────────

# Path to the directory containing Claude Code project JSONL session files
# Typically: ~/.claude/projects/  (contains subdirs per project, each with *.jsonl files)
# Agent HQ scans these files to compute daily token usage and cost estimates
# Leave blank to disable token stats
CLAUDE_PROJECTS_DIR=/home/youruser/.claude/projects

# Cost per input token in USD (default: $3 / 1,000,000 = claude-3-5-sonnet pricing)
INPUT_PRICE_PER_TOKEN=0.000003

# Cost per output token in USD (default: $15 / 1,000,000 = claude-3-5-sonnet pricing)
OUTPUT_PRICE_PER_TOKEN=0.000015

# ─── Redis (optional — enables BullMQ queue monitoring) ───────────────────────

# Redis connection URL
# Required only if you want to use BullMQ queues and the Bull Board dashboard
# Leave blank to run without Redis
REDIS_URL=redis://localhost:6379

# ─── PostgreSQL (optional — enables trends/history graphs) ────────────────────

# PostgreSQL connection string
# Required only if you want persistent daily_stats and hq_events history
# Leave blank to run without a database (stats will be in-memory only)
TRENDS_DB_URL=postgresql://user:password@localhost:5432/agent_hq

# ─── Example: wiring your own agents ─────────────────────────────────────────
#
# In your agent code, import agentRegistry and call:
#
#   import { emitAgentEvent } from './lib/agentRegistry.js';
#
#   emitAgentEvent('my-agent', 'working', { task: 'Processing job #42' });
#   emitAgentEvent('my-agent', 'idle');
#
# The dashboard SSE stream will instantly reflect the state change.
# See src/agents/example-agent.ts for a full working example.
